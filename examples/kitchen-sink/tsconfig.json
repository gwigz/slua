{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "lib": ["ESNext"],
    "types": ["@typescript-to-lua/language-extensions"],
    "rootDir": ".",
    "outDir": "out"
  },
  "tstl": {
    "luaTarget": "Luau",
    "luaLibImport": "inline",
    "noImplicitSelf": true,
    "noImplicitGlobalVariables": true,
    // NOTE: you should use "@gwigz/slua-tstl-plugin" instead of the local path
    // check the README for more details
    "luaPlugins": [{ "name": "../../packages/tstl-plugin/dist/index.js" }],
    "extension": "slua"
  },
  "include": ["*.ts"]
}
