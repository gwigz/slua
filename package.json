{
  "name": "@gwigz/slua",
  "private": true,
  "workspaces": [
    "packages/*",
    "tools/*",
    "apps/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bun run --filter '@gwigz/slua-tstl-plugin' build",
    "build:examples": "bun run build && bun run --filter '@gwigz/slua-example-*' build",
    "test": "bun test packages/ tools/",
    "generate": "bun tools/gen-types/generate.ts",
    "scrape": "bun run --filter '@gwigz/slua-scrape-wiki' scrape",
    "generate:docs": "bun tools/gen-api-docs/generate-ll.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "changeset": "bunx changeset",
    "ci:version": "bunx changeset version && bun update",
    "ci:publish": "bunx changeset publish --access public",
    "prepare": "husky"
  },
  "dependencies": {
    "@gwigz/tstl-bundle-flatten": "^1.0.1",
    "@typescript-to-lua/language-extensions": "^1.19.0",
    "typescript-to-lua": "^1.37.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.14",
    "husky": "^9.1.7",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.70.0",
    "rollup": "^4.62.0",
    "typescript": "6.0.3"
  },
  "patchedDependencies": {
    "monaco-editor@0.52.2": "patches/monaco-editor@0.52.2.patch"
  }
}
