{
  "name": "@gwigz/slua",
  "private": true,
  "workspaces": [
    "packages/*",
    "tools/*",
    "apps/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bun run --workspaces --if-present build",
    "build:examples": "bun run --filter '@gwigz/slua-example-*' build",
    "test": "bun test packages/ tools/",
    "generate": "bun tools/gen-types/src/index.ts refs/lsl-definitions/slua_definitions.yaml refs/lsl-definitions/lsl_definitions.yaml -o packages/types/index.d.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check ."
  },
  "dependencies": {
    "@typescript-to-lua/language-extensions": "^1.19.0",
    "typescript-to-lua": "^1.34.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "~5.9.3"
  },
  "patchedDependencies": {
    "monaco-editor@0.52.2": "patches/monaco-editor@0.52.2.patch"
  }
}
