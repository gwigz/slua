{
  "name": "@gwigz/slua-tstl-plugin",
  "version": "1.3.0",
  "description": "TypeScriptToLua plugin for targeting Second Life's SLua runtime",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gwigz/slua.git",
    "directory": "packages/tstl-plugin"
  },
  "files": [
    "dist",
    "!dist/__tests__"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./shake": {
      "types": "./dist/shake.d.ts",
      "default": "./dist/shake.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "bun test"
  },
  "dependencies": {
    "@gwigz/slua-types": "workspace:^",
    "typescript-to-lua": "^1.33.0"
  },
  "peerDependencies": {
    "rollup": "^4.0.0",
    "typescript": "~5.9.3"
  },
  "peerDependenciesMeta": {
    "rollup": {
      "optional": true
    }
  }
}
